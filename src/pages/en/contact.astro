---
import Layout from "../../layouts/layout.astro";
import { useTranslations } from "../../i18n/index";

const t = useTranslations("en");
---

<Layout title={t.contact.title} lang="en">
	<section class="px-4 py-12">
		<h1 class="text-4xl font-bold">{t.contact.title}</h1>

		<div class="mt-6 space-y-4">
			<p>{t.contact.phone}: +40 xxx xxx xxx</p>
			<p>{t.contact.email}: contact@example.com</p>
		</div>

		<a
			href="https://wa.me/40123456789"
			class="mt-8 inline-block rounded-lg bg-green-600 px-6 py-3 font-semibold"
		>
			{t.contact.whatsapp}
		</a>
	</section>
</Layout>

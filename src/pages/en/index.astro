---
import Layout from "../../layouts/layout.astro";
import { useTranslations } from "../../i18n/index";
import RouteMap from "../../components/RouteMap.astro";

const t = useTranslations("en");
---

<Layout title={t.home.title} lang="en">
	<section class="px-4 py-16">
		<h1 class="text-4xl font-bold leading-tight">{t.home.title}</h1>
		<p class="mt-4 text-lg text-gray-300">{t.home.subtitle}</p>
		<a
			href="https://wa.me/40123456789"
			class="mt-8 inline-block rounded-lg bg-green-600 px-6 py-3 font-semibold hover:bg-green-500"
		>
			{t.home.cta}
		</a>
	</section>

	<section class="px-4 py-12">
		<h2 class="text-2xl font-bold">{t.home.features.heading}</h2>
		<div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
			{
				t.home.features.items.map((f) => (
					<div class="rounded-lg bg-slate-800 p-6">
						<p class="text-3xl">{f.icon}</p>
						<h3 class="mt-3 text-lg font-semibold">{f.title}</h3>
						<p class="mt-2 text-sm text-gray-300">{f.description}</p>
					</div>
				))
			}
		</div>
	</section>

	<RouteMap lang="en" />

	<section class="mt-8 bg-slate-900 px-4 py-12">
		<h2 class="text-2xl font-bold">{t.home.contactStrip.heading}</h2>
		<p class="mt-2 text-gray-300">{t.home.contactStrip.subtitle}</p>
		<p class="mt-4 text-lg font-semibold">{t.home.contactStrip.phone}</p>
		<a
			href="https://wa.me/40123456789"
			class="mt-4 inline-block rounded-lg bg-green-600 px-6 py-3 font-semibold hover:bg-green-500"
		>
			{t.home.contactStrip.cta}
		</a>
	</section>
</Layout>

---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations, defaultLocale } from "../i18n/index";
import type { Locale } from "../i18n/index";

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = useTranslations(lang);

const homeUrl = getRelativeLocaleUrl(lang, "/");
const scheduleUrl = getRelativeLocaleUrl(lang, "/schedule");
const aboutUrl = getRelativeLocaleUrl(lang, "/about");
const contactUrl = getRelativeLocaleUrl(lang, "/contact");

const slug = Astro.url.pathname.replace(/^\/en/, "") || "/";
const roUrl = getRelativeLocaleUrl("ro", slug);
const enUrl = getRelativeLocaleUrl("en", slug);
---

<header
	class="sticky top-0 z-40 h-16 bg-slate-800 px-4 flex items-center justify-between text-white"
>
	<div class="text-lg font-bold">Transport</div>

	<div class="flex items-center gap-4">
		<div class="flex items-center gap-2 text-sm font-semibold">
			<a href={roUrl} class={lang === "ro" ? "text-white" : "text-gray-400 hover:text-white"}>RO</a>
			<span class="text-gray-500">|</span>
			<a href={enUrl} class={lang === "en" ? "text-white" : "text-gray-400 hover:text-white"}>EN</a>
		</div>

		<button
			id="menu-button"
			class="w-12 h-12 flex items-center justify-center text-2xl"
			aria-label="Open navigation menu"
		>
			☰
		</button>
	</div>
</header>

<nav
	id="mobile-menu"
	class="fixed inset-0 z-50 max-w-[85vw] bg-slate-900/95 backdrop-blur-sm text-white -translate-x-full transition-transform duration-300 ease-out"
>
	<div class="h-16 px-4 flex items-center justify-end">
		<button
			id="close-menu-button"
			class="w-12 h-12 flex items-center justify-center text-3xl"
			aria-label="Close navigation menu"
		>
			✕
		</button>
	</div>

	<div class="flex flex-col px-6 pt-8">
		<a href={homeUrl} class="py-4 text-3xl font-semibold">{t.nav.home}</a>
		<a href={scheduleUrl} class="py-4 text-3xl font-semibold">{t.nav.schedule}</a>
		<a href={aboutUrl} class="py-4 text-3xl font-semibold">{t.nav.about}</a>
		<a href={contactUrl} class="py-4 text-3xl font-semibold">{t.nav.contact}</a>
	</div>
</nav>

<script>
	const menu = document.getElementById("mobile-menu");
	const openButton = document.getElementById("menu-button");
	const closeButton = document.getElementById("close-menu-button");

	function openMenu() {
		menu?.classList.remove("-translate-x-full");
		menu?.classList.add("translate-x-0");
		document.body.style.overflow = "hidden";
	}

	function closeMenu() {
		menu?.classList.remove("translate-x-0");
		menu?.classList.add("-translate-x-full");
		document.body.style.overflow = "";
	}

	openButton?.addEventListener("click", openMenu);
	closeButton?.addEventListener("click", closeMenu);
	document.querySelectorAll("nav a").forEach((link) => {
		link.addEventListener("click", (e) => {
			e.preventDefault();
			const href = (e.currentTarget as HTMLAnchorElement).href;
			closeMenu();
			menu?.addEventListener("transitionend", () => {
				window.location.href = href;
			}, { once: true });
		});
	});
</script>

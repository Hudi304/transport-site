---
import type { useTranslations } from "../../i18n/index";

interface Props {
  basePath: string;
  contactTeaser: ReturnType<typeof useTranslations>["home"]["contactTeaser"];
  channels: ReturnType<typeof useTranslations>["contact"]["channels"];
}

const { basePath, contactTeaser, channels } = Astro.props;
const contactForm = contactTeaser.form;
---

<section class="bg-gray-50">
  <div class="max-w-page mx-auto px-5 py-10">
    <div class="lg:flex lg:gap-12 lg:items-start">
    <div class="lg:w-[340px] lg:shrink-0">
    <h2 class="text-2xl font-bold text-gray-900 uppercase tracking-wide">
      {contactTeaser.heading}
    </h2>
    <p class="text-gray-500 mt-3">
      {contactTeaser.intro}
    </p>

    <div class="mt-6 space-y-3 text-sm text-gray-700">
      <p class="flex items-center gap-2">
        <img src={`${basePath}/icons/phone-01.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
        {channels.phone.value}
      </p>
      <p class="flex items-center gap-2">
        <img src={`${basePath}/icons/akar-icons_whatsapp-fill.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
        {channels.whatsapp.value}
      </p>
      <p class="flex items-center gap-2">
        <img src={`${basePath}/icons/mail-02.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
        {channels.email.value}
      </p>
    </div>
    </div>

    <form id="contact-form" data-template={contactForm.whatsappTemplate} class="mt-6 lg:mt-0 lg:flex-1 space-y-4">
      <div class="space-y-4 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-4">
      <div>
        <label for="cf-name" class="block text-sm font-medium text-gray-700 mb-1">
          {contactForm.nameLabel} <span class="text-violet-500">*</span>
        </label>
        <input
          id="cf-name"
          name="name"
          type="text"
          required
          placeholder={contactForm.namePlaceholder}
          class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
        />
      </div>

      <div>
        <label for="cf-phone" class="block text-sm font-medium text-gray-700 mb-1">
          {contactForm.phoneLabel} <span class="text-violet-500">*</span>
        </label>
        <input
          id="cf-phone"
          name="phone"
          type="tel"
          required
          placeholder={contactForm.phonePlaceholder}
          class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
        />
      </div>
      </div>

      <div>
        <label for="cf-email" class="block text-sm font-medium text-gray-700 mb-1">
          {contactForm.emailLabel} <span class="text-violet-500">*</span>
        </label>
        <input
          id="cf-email"
          name="email"
          type="email"
          required
          placeholder={contactForm.emailPlaceholder}
          class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
        />
      </div>

      <div>
        <label for="cf-message" class="block text-sm font-medium text-gray-700 mb-1">
          {contactForm.messageLabel} <span class="text-violet-500">*</span>
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows={4}
          required
          maxlength={contactForm.messageMaxLength}
          placeholder={contactForm.messagePlaceholder}
          class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
        ></textarea>
        <p class="text-right text-xs text-gray-400 mt-1">
          <span id="cf-message-count">0</span>/{contactForm.messageMaxLength}
        </p>
      </div>

      <label class="flex items-start gap-2 text-sm text-gray-500">
        <input id="cf-consent" name="consent" type="checkbox" class="mt-1 rounded border-gray-300 text-violet-500 focus:ring-violet-300" />
        {contactForm.consent}
      </label>

      <button
        type="submit"
        class="w-full rounded-full bg-violet-500 text-white font-semibold py-3 hover:bg-violet-600 transition-colors"
      >
        {contactForm.submit}
      </button>
    </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const nameInput = document.getElementById("cf-name") as HTMLInputElement;
  const phoneInput = document.getElementById("cf-phone") as HTMLInputElement;
  const emailInput = document.getElementById("cf-email") as HTMLInputElement;
  const messageInput = document.getElementById("cf-message") as HTMLTextAreaElement;
  const messageCount = document.getElementById("cf-message-count") as HTMLElement;

  const template = form.dataset.template ?? "";

  messageInput.addEventListener("input", () => {
    messageCount.textContent = String(messageInput.value.length);
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const message = template
      .replace("{name}", nameInput.value)
      .replace("{phone}", phoneInput.value)
      .replace("{email}", emailInput.value)
      .replace("{message}", messageInput.value);
    window.open(`https://wa.me/40123456789?text=${encodeURIComponent(message)}`, "_blank");
  });
</script>

---
import type { useTranslations } from "../../i18n/index";

interface Props {
  basePath: string;
  privateVip: ReturnType<typeof useTranslations>["home"]["privateVip"];
  whatsappHref: string;
}

const { basePath, privateVip, whatsappHref } = Astro.props;
---

<section class="bg-gray-50 lg:bg-white">
  <div class="lg:max-w-page lg:mx-auto lg:px-5 lg:py-10">
    <div class="lg:flex lg:items-stretch lg:rounded-2xl lg:overflow-hidden">
      <div class="max-w-page mx-auto px-5 py-10 lg:max-w-none lg:mx-0 lg:px-0 lg:py-0 lg:w-1/2 lg:bg-gray-50 lg:flex lg:flex-col lg:justify-center lg:p-12">
        <h2 class="text-3xl font-extrabold text-gray-900 uppercase leading-tight">
          {privateVip.heading}
        </h2>
        <p class="text-gray-500 mt-3">
          {privateVip.intro}
        </p>
        <ul class="list-disc pl-5 mt-3 space-y-2 text-gray-700">
          {privateVip.options.map((option) => (
            <li>
              <span class="font-bold text-gray-900">{option.label}</span> - {option.detail}
            </li>
          ))}
        </ul>
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-violet-500 text-white font-semibold px-8 py-3 mt-6 hover:bg-violet-600 transition-colors lg:self-start"
        >
          {privateVip.cta}
        </a>
      </div>

      <img
        src={`${basePath}/img/aeroport.jpg`}
        alt={privateVip.heading}
        class="w-full h-64 object-cover lg:w-1/2 lg:h-[560px]"
      />
    </div>
  </div>
</section>

---
interface Props {
  basePath: string;
}

const { basePath } = Astro.props;
---

<section class="relative w-full h-[380px] overflow-hidden flex lg:items-start items-end">

  <img
    src={`${basePath}/img/hero.png`}
    alt="Hero"
    class="absolute inset-0 w-full h-full object-cover"
  />

  <!-- px-4 matches the nav outer wrapper; px-5 matches the nav header inner padding -->
  <div class="relative z-10 w-full px-4 ">


    <div class="max-w-page mx-auto px-5 pb-10 lg:pb-16 max-w-[1440px]  ">
      <span
        class="text-white leading-none tracking-normal text-5xl flex max-lg:flex-col mt-40"
        style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 700; text-shadow: 0px 4px 8px #00000026;"
      >
        <span class="mr-5">TRANSPORT</span>
        <span>AEROPORT</span>
      </span>
    </div>
  </div>

</section>

<div class="h-1 bg-violet-500" aria-hidden="true"></div>

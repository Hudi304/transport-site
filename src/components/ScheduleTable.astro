---
import { routes } from "../data/schedule";
import { computeStopTimes } from "../utils/schedule";
import { useTranslations, defaultLocale } from "../i18n/index";
import type { Locale } from "../i18n/index";

interface Props {
	lang?: Locale;
}

const { lang = defaultLocale } = Astro.props;
const t = useTranslations(lang);
---

<div class="mt-8 space-y-10">
	{
		routes.map((route) => {
			const stops = route.stops;
			const colTimes = route.departures.map((dep) =>
				computeStopTimes(stops, dep.time)
			);

			return (
				<div>
					<h2 class="mb-4 text-xl font-semibold">{route.heading}</h2>
					<div class="overflow-x-auto rounded-lg border border-slate-600">
						<table class="w-full text-left text-sm">
							<thead class="bg-slate-900 text-slate-300">
								<tr>
									<th class="px-4 py-3 font-semibold">{t.schedule.table.stop}</th>
									{route.departures.map((dep) => (
										<th class="px-4 py-3 font-semibold text-center">
											<span class="block text-white text-base font-bold">{dep.time}</span>
											<span class="text-xs text-slate-400">{t.schedule.days[dep.days]}</span>
										</th>
									))}
								</tr>
							</thead>

							<tbody class="bg-slate-800">
								{stops.map((stop, stopIdx) => (
									<tr class="border-t border-slate-700 even:bg-slate-700/40">
										<td class="px-4 py-3 font-medium text-slate-100">{stop.name}</td>
										{colTimes.map((col) => (
											<td class="px-4 py-3 text-center tabular-nums text-slate-200">
												{col[stopIdx].time}
											</td>
										))}
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			);
		})
	}
</div>

---
import LandingLayout from "../../layouts/landing_layout.astro";
import RouteMap from "../RouteMap.astro";
import { useTranslations, defaultLocale } from "../../i18n/index";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "../../i18n/index";

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = useTranslations(lang);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const contactUrl = getRelativeLocaleUrl(lang, "/contact");

const itinerary = t.home.availableRides.card.itinerary;
const whatsappHref = `https://wa.me/40123456789?text=${encodeURIComponent(itinerary.whatsappMessage)}`;

const privateVip = t.home.privateVip;
const privateVipWhatsappHref = `https://wa.me/40123456789?text=${encodeURIComponent(privateVip.whatsappMessage)}`;

const contactForm = t.home.contactTeaser.form;
const footer = t.footer;
const copyrightText = footer.copyright.replace("{year}", String(new Date().getFullYear()));

const featureIcons: Record<string, string> = {
  thumbsUp: "thumbs-up.svg",
  star: "award-01.svg",
  shield: "shield-tick.svg",
  chat: "message-check-circle.svg",
};
---

<LandingLayout title={t.home.title} lang={lang}>

  <!-- Hero -->
  <section class="relative w-full min-h-[420px] sm:min-h-[520px] lg:min-h-[600px] flex items-end">

    <img
      src={`${basePath}/img/hero.png`}
      alt="Hero"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- px-4 matches the nav outer wrapper; px-5 matches the nav header inner padding -->
    <div class="relative z-10 w-full px-4">
      <div class="max-w-page mx-auto px-5 pb-10 lg:pb-16">
        <span
          class="text-white leading-none tracking-normal text-4xl sm:text-5xl lg:text-6xl"
          style="font-family: 'IBM Plex Sans', sans-serif; font-weight: 700; text-shadow: 0px 4px 8px #00000026;"
        >
          TRANSPORT AEROPORT
        </span>
      </div>
    </div>

  </section>

  <div class="h-1 bg-violet-500" aria-hidden="true"></div>

  <!-- Curse disponibile -->
  <section class="relative overflow-hidden">
    <img
      src={`${basePath}/world_map.svg`}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-25 pointer-events-none"
    />

    <div class="relative z-10 max-w-page mx-auto px-5 py-10">
      <div class="lg:flex lg:items-baseline lg:gap-4">
        <h2 class="text-gray-900 font-bold uppercase tracking-wide text-2xl">
          {t.home.availableRides.heading}
        </h2>
        <p class="text-violet-500 font-medium mt-1 lg:mt-0">
          {t.home.availableRides.period}
        </p>
      </div>

      <div class="mt-6 lg:flex lg:justify-center lg:gap-6 lg:items-start">
      <div class="lg:w-[560px] lg:shrink-0 rounded-2xl border-2 border-dashed border-violet-200 bg-white p-5">
        <h3 class="text-violet-500 font-bold uppercase tracking-wide pb-3 border-b border-gray-100">
          {t.home.availableRides.card.title}
        </h3>

        <div class="mt-4">
          <p class="text-gray-500 text-sm mb-1">{t.home.availableRides.card.dayLabel}</p>
          <div class="flex items-center justify-between rounded-full border border-violet-300 px-4 py-3">
            <span class="text-gray-900 font-medium">{t.home.availableRides.card.dayValue}</span>
            <svg class="w-5 h-5 shrink-0 text-violet-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>

        <div class="hidden lg:flex lg:justify-center lg:py-1">
          <svg class="w-4 h-4 text-violet-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v13.5m0 0-4.5-4.5m4.5 4.5 4.5-4.5" />
          </svg>
        </div>

        <div class="mt-4 lg:mt-0">
          <p class="text-gray-500 text-sm mb-1">{t.home.availableRides.card.locationLabel}</p>
          <div class="flex items-center justify-between rounded-full border border-violet-300 px-4 py-3">
            <span class="text-gray-900 font-medium">{t.home.availableRides.card.locationValue}</span>
            <svg class="w-5 h-5 shrink-0 text-violet-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>
      </div>

      <div class="mt-4 lg:mt-0 lg:w-[560px] lg:shrink-0 rounded-2xl border-2 border-dashed border-violet-200 bg-white p-5">
        <div class="flex items-center justify-between pb-3 border-b border-gray-100">
          <h3 class="text-violet-500 font-bold uppercase tracking-wide">
            {itinerary.label}
          </h3>
          <div class="flex items-center justify-center gap-2 h-9 px-2 lg:px-4 rounded-lg border border-violet-300 shrink-0">
            <svg class="w-5 h-5 text-violet-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span class="hidden lg:inline text-violet-500 text-sm font-medium whitespace-nowrap">{itinerary.viewOnMap}</span>
          </div>
        </div>

        <div class="flex items-center justify-between mt-4">
          <p class="text-gray-900 font-bold">{itinerary.departureLabel} {itinerary.departureTime}</p>
          <span class="inline-flex items-center gap-1 rounded-full bg-violet-50 text-violet-600 text-sm font-medium px-3 py-1">
            <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            {itinerary.duration}
          </span>
        </div>

        <div class="relative mt-5">
          <div class="absolute left-[5px] top-1 bottom-1 w-px bg-gray-200"></div>

          {itinerary.stops.map((stop, i) => {
            const isLast = i === itinerary.stops.length - 1;
            return (
              <div class="relative flex gap-3 pb-4 last:pb-0">
                <div class:list={["mt-1.5 w-2.5 h-2.5 rounded-full shrink-0", isLast ? "bg-violet-500" : "bg-gray-300"]}></div>
                <div>
                  <p class:list={["font-semibold", isLast ? "text-violet-500" : "text-gray-900"]}>{stop.name}</p>
                  <p class="text-gray-400 text-sm">{stop.time}</p>
                  {stop.note && (
                    <p class="flex items-center gap-1 text-violet-500 text-sm mt-0.5">
                      <svg class="w-3.5 h-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                      </svg>
                      {stop.note}
                    </p>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        <div class="mt-2 pt-4 border-t border-gray-100 space-y-2">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">{itinerary.dateLabel}</span>
            <span class="text-gray-900 font-medium">{itinerary.dateValue}</span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">{itinerary.pickupLabel}</span>
            <span class="text-gray-900 font-medium">{itinerary.pickupValue}</span>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">{itinerary.arrivalLabel}</span>
            <span class="text-gray-900 font-medium">{itinerary.arrivalValue}</span>
          </div>
        </div>

        <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
          <span class="text-violet-500 font-bold">{itinerary.totalLabel}</span>
          <span class="text-violet-500 font-bold">
            {itinerary.totalPrice}
            <span class="text-violet-400 font-medium text-sm">{itinerary.totalUnit}</span>
          </span>
        </div>

        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex w-full items-center justify-center gap-3 rounded-full bg-green-600 px-6 py-3 font-semibold text-white hover:bg-green-500 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          {itinerary.cta}
        </a>
      </div>
      </div>
    </div>
  </section>

  <!-- Transport Privat VIP -->
  <section class="bg-gray-50 lg:bg-white">
    <div class="lg:max-w-page lg:mx-auto lg:px-5 lg:py-10">
      <div class="lg:flex lg:items-stretch lg:rounded-2xl lg:overflow-hidden">
        <div class="max-w-page mx-auto px-5 py-10 lg:max-w-none lg:mx-0 lg:px-0 lg:py-0 lg:w-1/2 lg:bg-gray-50 lg:flex lg:flex-col lg:justify-center lg:p-12">
          <h2 class="text-3xl font-extrabold text-gray-900 uppercase leading-tight">
            {privateVip.heading}
          </h2>
          <p class="text-gray-500 mt-3">
            {privateVip.intro}
          </p>
          <ul class="list-disc pl-5 mt-3 space-y-2 text-gray-700">
            {privateVip.options.map((option) => (
              <li>
                <span class="font-bold text-gray-900">{option.label}</span> - {option.detail}
              </li>
            ))}
          </ul>
          <a
            href={privateVipWhatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-violet-500 text-white font-semibold px-8 py-3 mt-6 hover:bg-violet-600 transition-colors lg:self-start"
          >
            {privateVip.cta}
          </a>
        </div>

        <img
          src={`${basePath}/img/aeroport.jpg`}
          alt={privateVip.heading}
          class="w-full h-64 object-cover lg:w-1/2 lg:h-[560px]"
        />
      </div>
    </div>
  </section>

  <!-- Despre noi -->
  <section class="bg-white">
    <div class="max-w-page mx-auto px-5 py-10">
      <div class="lg:flex lg:gap-12 lg:items-start">
        <div class="lg:w-1/2">
          <h2 class="text-2xl font-bold text-gray-900 uppercase tracking-wide">
            {t.home.about.heading}
          </h2>

          <div class="mt-4 space-y-4 text-gray-500">
            {t.home.about.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>

        <div class="mt-8 lg:mt-0 lg:w-1/2 grid grid-cols-1 lg:grid-cols-2 gap-4">
          {t.home.about.features.map((feature) => (
            <div class="rounded-2xl bg-gray-50 shadow-sm p-6 flex flex-col items-center text-center gap-3">
              <img src={`${basePath}/icons/${featureIcons[feature.icon]}`} alt="" aria-hidden="true" class="w-10 h-10" />
              <p class="font-semibold text-gray-900">{feature.title}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contacteaza-ne -->
  <section class="bg-gray-50">
    <div class="max-w-page mx-auto px-5 py-10">
      <div class="lg:flex lg:gap-12 lg:items-start">
      <div class="lg:w-[340px] lg:shrink-0">
      <h2 class="text-2xl font-bold text-gray-900 uppercase tracking-wide">
        {t.home.contactTeaser.heading}
      </h2>
      <p class="text-gray-500 mt-3">
        {t.home.contactTeaser.intro}
      </p>

      <div class="mt-6 space-y-3 text-sm text-gray-700">
        <p class="flex items-center gap-2">
          <img src={`${basePath}/icons/phone-01.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
          {t.contact.channels.phone.value}
        </p>
        <p class="flex items-center gap-2">
          <img src={`${basePath}/icons/akar-icons_whatsapp-fill.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
          {t.contact.channels.whatsapp.value}
        </p>
        <p class="flex items-center gap-2">
          <img src={`${basePath}/icons/mail-02.svg`} alt="" aria-hidden="true" class="w-5 h-5 shrink-0" />
          {t.contact.channels.email.value}
        </p>
      </div>
      </div>

      <form id="contact-form" data-template={contactForm.whatsappTemplate} class="mt-6 lg:mt-0 lg:flex-1 space-y-4">
        <div class="space-y-4 lg:space-y-0 lg:grid lg:grid-cols-2 lg:gap-4">
        <div>
          <label for="cf-name" class="block text-sm font-medium text-gray-700 mb-1">
            {contactForm.nameLabel} <span class="text-violet-500">*</span>
          </label>
          <input
            id="cf-name"
            name="name"
            type="text"
            required
            placeholder={contactForm.namePlaceholder}
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
          />
        </div>

        <div>
          <label for="cf-phone" class="block text-sm font-medium text-gray-700 mb-1">
            {contactForm.phoneLabel} <span class="text-violet-500">*</span>
          </label>
          <input
            id="cf-phone"
            name="phone"
            type="tel"
            required
            placeholder={contactForm.phonePlaceholder}
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
          />
        </div>
        </div>

        <div>
          <label for="cf-email" class="block text-sm font-medium text-gray-700 mb-1">
            {contactForm.emailLabel} <span class="text-violet-500">*</span>
          </label>
          <input
            id="cf-email"
            name="email"
            type="email"
            required
            placeholder={contactForm.emailPlaceholder}
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
          />
        </div>

        <div>
          <label for="cf-message" class="block text-sm font-medium text-gray-700 mb-1">
            {contactForm.messageLabel} <span class="text-violet-500">*</span>
          </label>
          <textarea
            id="cf-message"
            name="message"
            rows={4}
            required
            maxlength={contactForm.messageMaxLength}
            placeholder={contactForm.messagePlaceholder}
            class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-300"
          ></textarea>
          <p class="text-right text-xs text-gray-400 mt-1">
            <span id="cf-message-count">0</span>/{contactForm.messageMaxLength}
          </p>
        </div>

        <label class="flex items-start gap-2 text-sm text-gray-500">
          <input id="cf-consent" name="consent" type="checkbox" class="mt-1 rounded border-gray-300 text-violet-500 focus:ring-violet-300" />
          {contactForm.consent}
        </label>

        <button
          type="submit"
          class="w-full rounded-full bg-violet-500 text-white font-semibold py-3 hover:bg-violet-600 transition-colors"
        >
          {contactForm.submit}
        </button>
      </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-purple-500 text-white">
    <div class="max-w-page mx-auto px-5 py-10">
      <div class="lg:flex lg:items-stretch lg:gap-16">
        <div class="lg:shrink-0">
          <img src={`${basePath}/branding/zabo_logo_white.svg`} alt="ZaboTravel" class="h-7 w-auto" />
          <p class="text-gray-300 text-xs mt-1 uppercase tracking-wide">{footer.tagline}</p>
        </div>

        <div class="hidden lg:block lg:w-px lg:bg-white/10"></div>

        <div class="border-t border-white/10 mt-6 pt-6 lg:border-t-0 lg:mt-0 lg:pt-0 lg:flex-1">
          <h3 class="font-bold">{footer.supportHeading}</h3>
          <ul class="mt-3 space-y-2 text-gray-300 text-sm">
            <li><a href="#" class="hover:text-white">{footer.links.terms}</a></li>
            <li><a href="#" class="hover:text-white">{footer.links.privacy}</a></li>
            <li><a href="#" class="hover:text-white">{footer.links.faq}</a></li>
            <li><a href={contactUrl} class="hover:text-white">{footer.links.contact}</a></li>
          </ul>
        </div>
      </div>

      <div class="border-t border-white/10 mt-6 pt-4 text-center text-gray-400 text-xs space-y-1">
        <p>{copyrightText}</p>
        <p>{footer.rights}</p>
      </div>
    </div>
  </footer>
</LandingLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const nameInput = document.getElementById("cf-name") as HTMLInputElement;
  const phoneInput = document.getElementById("cf-phone") as HTMLInputElement;
  const emailInput = document.getElementById("cf-email") as HTMLInputElement;
  const messageInput = document.getElementById("cf-message") as HTMLTextAreaElement;
  const messageCount = document.getElementById("cf-message-count") as HTMLElement;

  const template = form.dataset.template ?? "";

  messageInput.addEventListener("input", () => {
    messageCount.textContent = String(messageInput.value.length);
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const message = template
      .replace("{name}", nameInput.value)
      .replace("{phone}", phoneInput.value)
      .replace("{email}", emailInput.value)
      .replace("{message}", messageInput.value);
    window.open(`https://wa.me/40123456789?text=${encodeURIComponent(message)}`, "_blank");
  });
</script>

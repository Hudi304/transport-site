---
import LandingLayout from "../../layouts/landing_layout.astro";
import Hero from "../landing/Hero.astro";
import AvailableRidesSection from "../landing/AvailableRidesSection.astro";
import PrivateVipSection from "../landing/PrivateVipSection.astro";
import AboutSection from "../landing/AboutSection.astro";
import ContactSection from "../landing/ContactSection.astro";
import Footer from "../landing/Footer.astro";
import { useTranslations, defaultLocale } from "../../i18n/index";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { Locale } from "../../i18n/index";

const lang = (Astro.currentLocale ?? defaultLocale) as Locale;
const t = useTranslations(lang);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const contactUrl = getRelativeLocaleUrl(lang, "/contact");

const itinerary = t.home.availableRides.card.itinerary;
const whatsappHref = `https://wa.me/40123456789?text=${encodeURIComponent(itinerary.whatsappMessage)}`;

const privateVip = t.home.privateVip;
const privateVipWhatsappHref = `https://wa.me/40123456789?text=${encodeURIComponent(privateVip.whatsappMessage)}`;

const footer = t.footer;
const copyrightText = footer.copyright.replace("{year}", String(new Date().getFullYear()));

const featureIcons: Record<string, string> = {
  thumbsUp: "thumbs-up.svg",
  star: "award-01.svg",
  shield: "shield-tick.svg",
  chat: "message-check-circle.svg",
};
---

<LandingLayout title={t.home.title} lang={lang}>
  <Hero basePath={basePath} />

  <AvailableRidesSection
    basePath={basePath}
    availableRides={t.home.availableRides}
    whatsappHref={whatsappHref}
  />

  <PrivateVipSection
    basePath={basePath}
    privateVip={privateVip}
    whatsappHref={privateVipWhatsappHref}
  />

  <AboutSection
    basePath={basePath}
    about={t.home.about}
    featureIcons={featureIcons}
  />

  <ContactSection
    basePath={basePath}
    contactTeaser={t.home.contactTeaser}
    channels={t.contact.channels}
  />

  <Footer
    basePath={basePath}
    footer={footer}
    contactUrl={contactUrl}
    copyrightText={copyrightText}
  />
</LandingLayout>
